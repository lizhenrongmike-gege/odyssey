---
import { TextSection } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import HeroSection from '../../components/sections/heros/HeroSection.astro';

const seo = {
	title: 'About | Cilo Media Studio',
	description:
		'Cilo Media Studio is a Bay Area, social-first marketing agency working in influencer marketing, cold outbound, and SEO.',
};
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<h1>About Cilo Media Studio</h1>
			<p>
				Cilo Media Studio is a Bay Area marketing agency built around one idea:
				social-first marketing that actually moves the needle for the businesses
				we work with.
			</p>
		</div>
		<picture slot="image-container">
			<img
				src="/assets/images/cilo/about.jpg"
				alt="The Cilo Media Studio team celebrating a win during a working session"
				id="home-hero-image"
				width="1600"
				height="900"
			/>
		</picture>
	</HeroSection>
	<TextSection narrow>
		<p>
			We started in the world of food and restaurant marketing, running
			influencer campaigns that filled tables and built real local buzz. That
			work taught us how to match the right creators with the right audiences —
			and how to turn social attention into paying customers.
		</p>
		<p>
			Today we work across industries and increasingly with B2B brands. Our
			campaigns pair influencer and social media marketing with cold outbound and
			SEO, so the audiences we reach don't just engage — they convert.
		</p>
		<p>
			We keep things honest and concrete. Every engagement is built around your
			goals, the audiences you're trying to reach, and results you can actually
			measure. No vanity metrics, no guesswork — just marketing that earns its
			place in your budget.
		</p>
		<!-- TODO (optional): add a short founder paragraph here. -->
		<!-- TODO: add 2–3 real client results or testimonials once available. -->
	</TextSection>
</Layout>
