---
import { Container, Button, TextCardSection } from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';

const seo = {
	title: 'Thank you | Cilo Media Studio',
	description: 'Thanks for reaching out to Cilo Media Studio.',
};
---

<Layout seo={seo}>
	<Container>
		<TextCardSection>
			<h1>Thank you!</h1>
			<p>
				Thanks for reaching out to Cilo Media Studio. We've received your message
				and will get back to you shortly.
			</p>
			<div class="thank-you__cta">
				<Button href="/">Back to home</Button>
			</div>
		</TextCardSection>
	</Container>
</Layout>

<style>
	.thank-you__cta {
		display: flex;
		justify-content: center;
		margin-top: 1.5rem;
	}
</style>
