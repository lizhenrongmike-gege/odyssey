---
import { Container, Button, CtaCardSection } from '@components/odyssey-theme';

import Layout from '../layouts/Page.astro';
import HomeHeroSection from '../components/sections/heros/HomeHeroSection.astro';

const services = [
	{
		title: 'Influencer & Social Media Marketing',
		body: 'We build creator partnerships and social campaigns that put your brand in front of the audiences most likely to buy — from food influencers to niche B2B voices.',
	},
	{
		title: 'Cold Outbound Campaigns',
		body: 'Targeted outreach that finds new customers and partners and starts real conversations at scale.',
	},
	{
		title: 'SEO & Optimization',
		body: 'We sharpen your discoverability and conversion so the traffic you earn actually turns into business.',
	},
];
---

<Layout>
	<HomeHeroSection />

	<Container>
		<section id="services" class="services__section">
			<div class="services__intro">
				<h2>What we do</h2>
				<p>
					Cilo Media Studio is a social-first marketing agency. We help
					restaurants and growing brands reach the right people — and turn that
					attention into real, measurable business.
				</p>
			</div>
			<div class="services__grid">
				{
					services.map((service) => (
						<article class="service-card">
							<h3>{service.title}</h3>
							<p>{service.body}</p>
						</article>
					))
				}
			</div>
		</section>
	</Container>

	<CtaCardSection>
		<h2>Ready to grow? Let's talk.</h2>
		<p>
			Tell us about your brand and who you're trying to reach. We'll show you how
			a social-first campaign can get you there.
		</p>
		<Button href="/company/contact">Book a call</Button>
	</CtaCardSection>
</Layout>

<style>
	.services__section {
		margin: var(--section-margin) auto;
		scroll-margin-top: 2rem;
	}
	.services__intro {
		max-width: var(--container-max-width-narrow);
		margin: 0 auto 2rem auto;
		text-align: center;
	}
	.services__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--theme-grid-gap);
	}
	.service-card {
		padding: 2rem;
		background-color: var(--theme-surface-1);
		color: var(--theme-on-surface-1);
		border: 1px solid oklch(0.9 0.01 264);
		border-radius: var(--theme-shape-radius);
		transition: transform var(--theme-transition),
			box-shadow var(--theme-transition), border-color var(--theme-transition);
	}
	.service-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 22px 40px -28px oklch(0.24 0.06 264 / 0.4);
		border-color: var(--theme-accent);
	}
	.service-card h3 {
		margin-top: 0;
	}
	@media (max-width: 768px) {
		.services__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
